{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_BASE_URL": "https://your-project.vercel.app"
  },
  "functions": {
    "app/api/webhook/route.ts": {
      "maxDuration": 30
    },
    "app/results/page.tsx": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/drip-emails",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/facebook-sequence",
      "schedule": "0 0 * * 5"
    },
    {
      "path": "/api/cron/facebook-sequence",
      "schedule": "0 16 * * 0"
    }
  ]
}
